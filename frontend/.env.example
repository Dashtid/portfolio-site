# API Configuration
# Local dev: http://localhost:8000
# Production (post-INFRA-003): https://api.dashti.se
VITE_API_URL=http://localhost:8000

# Application
VITE_APP_VERSION=1.0.0

# Error Tracking (Sentry)
VITE_ERROR_TRACKING_ENABLED=true
VITE_SENTRY_DSN=""  # Sentry DSN for frontend error tracking
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions for performance monitoring

# Performance Monitoring
VITE_METRICS_ENABLED=true
