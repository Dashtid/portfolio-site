{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ssg": "vite-ssg build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:visual": "playwright test visual.spec.ts --project=chromium",
    "test:e2e:visual:update": "playwright test visual.spec.ts --project=chromium --update-snapshots",
    "test:e2e:docker": "docker run --rm --ipc=host -v \"$(pwd):/app\" -w /app mcr.microsoft.com/playwright:v1.60.0-noble npx playwright test",
    "test:e2e:visual:docker": "docker run --rm --ipc=host -v \"$(pwd):/app\" -w /app mcr.microsoft.com/playwright:v1.60.0-noble npx playwright test visual.spec.ts --project=chromium",
    "test:e2e:visual:update-docker": "docker run --rm --ipc=host -v \"$(pwd):/app\" -w /app mcr.microsoft.com/playwright:v1.60.0-noble npx playwright test visual.spec.ts --project=chromium --update-snapshots",
    "lighthouse": "lhci autorun --config=../.github/lighthouse/lighthouserc.json",
    "lighthouse:collect": "lhci collect --config=../.github/lighthouse/lighthouserc.json",
    "coverage": "vitest run --coverage",
    "analyze": "vite build && start dist/stats.html",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "prepare": "husky || true",
    "images:avif": "node scripts/convert-to-avif.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@sentry/vue": "^10.55.0",
    "@tailwindcss/vite": "^4.3.1",
    "@unhead/vue": "^2.1.13",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "gsap": "^3.14.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.35",
    "vue-router": "^4.6.3",
    "web-vitals": "^5.1.0"
  },
  "overrides": {
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.5.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "1.60.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/node": "^24.10.1",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.0.14",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.3.2"
  }
}
