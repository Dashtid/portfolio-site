# Supply-chain hardening (D3-SEC-05): never execute install lifecycle
# scripts — the propagation vector for the 2025-26 npm worm attacks
# (Shai-Hulud class). Everything this build needs ships as prebuilt
# platform binaries via optionalDependencies (esbuild, sharp,
# @sentry/cli), verified against the lockfile; nothing requires a
# postinstall to compile. Applies to local dev, CI, and the Vercel
# install (installCommand npm ci picks this up).
ignore-scripts=true
