        "comments": {
          "totalCount": 6,
          "nodes": [
            {
              "author": {"login": "Dashtid"},
              "createdAt": "2026-05-15T10:00:00Z",
              "bodyText": "I've reproduced this on Alpine 3.20.3 with both syft+grype 0.81 and 0.82. The musl ECID is matching against a vendor-overridden NVD record."
            },
            {
              "author": {"login": "github-actions[bot]"},
              "createdAt": "2026-05-15T10:01:00Z",
              "bodyText": "Thanks for the report! A maintainer will triage shortly."
            },
            {
              "author": {"login": "Dashtid"},
              "createdAt": "2026-06-10T11:45:00Z",
              "bodyText": "Pinning vulnerability-db to v6 works around it; flagging in case anyone else hits the same wall."
            }
          ]
        }
